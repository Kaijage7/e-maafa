# Copy this file to ".env" and fill in REAL values. The .env file is git-ignored — never commit secrets.
#
# Generate a strong JWT secret (>=32 bytes):
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#   # or: openssl rand -hex 32
DMIS_AUTH_JWT_SECRET=replace-with-a-real-32-byte-random-secret

# Optional — override the database password (defaults to dmis_pass for local/staging only).
# DB_PASSWORD=use-a-strong-password-in-production

# ── SMS gateway (M-Gov) — set these to send REAL SMS. Left blank, sends are logged as 'pending'. ──
MGOV_API_KEY=
MGOV_SYSTEM_ID=
MGOV_SMS_URL=
MGOV_MOBILE_SERVICE_ID=
MGOV_SENDER_ID=

# ── Email (SMTP, e.g. Gmail app password) — set these to send REAL email; blank = logged as 'pending'. ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=e-MAAFA
